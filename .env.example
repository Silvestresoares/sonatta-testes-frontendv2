# ============================================================
# CONFIGURAÇÕES DO FRONTEND - SONATTA
# ============================================================
# Copie este arquivo para .env e configure conforme necessário

# ============================================================
# API
# ============================================================

# URL da API backend
VITE_API_URL=http://localhost:3001

# ============================================================
# MODO DEBUG
# ============================================================

# Ativar modo debug (true/false)
VITE_DEBUG=false

# ============================================================
# PRODUÇÃO
# ============================================================

# URLs de produção (descomente quando necessário)
# VITE_API_URL=https://api.sonatta.com.br
# VITE_APP_URL=https://sonatta.com.br

# ============================================================
# ANALYTICS (OPCIONAL)
# ============================================================

# Google Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX

# ============================================================
# FEATURE FLAGS (OPCIONAL)
# ============================================================

# Ativar/desativar funcionalidades
# VITE_ENABLE_OFFLINE=false
# VITE_ENABLE_PWA=false
# VITE_ENABLE_NOTIFICATIONS=true
